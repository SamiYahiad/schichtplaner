# =============================================================================
# Schichtplaner 2.0 - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before deploying.

# --- Database ---
# These seed the Postgres container itself; docker-compose.yml builds
# DATABASE_URL for the app automatically from these values - you do not
# need to (and the app container will ignore it if you do) set DATABASE_URL
# directly here.
POSTGRES_USER="schichtplaner"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
POSTGRES_DB="schichtplaner"

# --- Authentication ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_RANDOM_SECRET"
# NEXTAUTH_URL is not set here: docker-compose.yml derives it as https://$DOMAIN
# automatically (the app is only ever reachable through Caddy on that origin), so
# there is a single source of truth instead of two URLs that can drift out of sync.

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Redis ---
REDIS_URL="redis://redis:6379"

# --- Object Storage (MinIO / S3) ---
# MINIO_ROOT_USER/PASSWORD seed the MinIO container's admin account.
# The app's S3 credentials are the same as MINIO_ROOT_USER/MINIO_ROOT_PASSWORD,
# derived automatically by docker-compose.yml - you do not need to (and the
# app container will ignore it if you do) set S3_ACCESS_KEY/S3_SECRET_KEY
# directly here.
S3_ENDPOINT="http://minio:9000"
MINIO_ROOT_USER="CHANGE_ME"
MINIO_ROOT_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
S3_BUCKET="schichtplaner"

# --- Caddy (reverse proxy) ---
# Domain for automatic HTTPS via Let's Encrypt
# Use 'localhost' for local development
DOMAIN="schichtplaner.example.com"
